{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode-slim"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "plan": {
      "mode": "all"
    }
  },
  "lsp": true,
  "instructions": ["C:/Users/mehdi/.config/opencode/prefs.md"],
  "permission": {
    "*": "allow",
    "edit": "ask",
    "bash": "allow"
  },
  "experimental": {
    "hook": {
      "session_completed": [
        {
          "command": [
            "pwsh",
            "-NoProfile",
            "-File",
            "C:/Users/mehdi/.config/opencode/scripts/auto-commit.ps1"
          ]
        }
      ]
    }
  }
}
